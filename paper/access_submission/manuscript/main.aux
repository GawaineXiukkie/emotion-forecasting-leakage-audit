\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Complete next-own-utterance self-shift ROC--AUC (three-seed mean). The full causal dialogue history is retained; only the supervised target index changes. Trans-Pred is information-matched. DailyDialog gains all survive the separate 24-comparison Holm correction ($p_{\fontencoding  {T1}\selectfont  {a}dj}=.0048$); other corrected comparisons are not significant.}}{7}{table.6}\protected@file@percent }
\newlabel{tab:selfmodels}{{6}{7}{Complete next-own-utterance self-shift ROC--AUC (three-seed mean). The full causal dialogue history is retained; only the supervised target index changes. Trans-Pred is information-matched. DailyDialog gains all survive the separate 24-comparison Holm correction ($p_{\rm adj}=.0048$); other corrected comparisons are not significant}{table.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Deployable shift ROC--AUC (three-seed mean). Trans-Pred uses current-emotion predictions from a train-only linear classifier; learned models receive no gold emotion. Bold values exceed the matched baseline. DailyDialog is duplicate-free. MM rows are feature-source sensitivity analyses, not independent primary corpora. Inference uses a seed--dialogue hierarchical bootstrap and paired dialogue-cluster permutation; Holm correction spans 72 declared deployable+oracle comparisons. All six DailyDialog gains, all six MELD-mm gains, and DialogueRNN's MELD gain survive correction.}}{7}{table.7}\protected@file@percent }
\newlabel{tab:main}{{7}{7}{Deployable shift ROC--AUC (three-seed mean). Trans-Pred uses current-emotion predictions from a train-only linear classifier; learned models receive no gold emotion. Bold values exceed the matched baseline. DailyDialog is duplicate-free. MM rows are feature-source sensitivity analyses, not independent primary corpora. Inference uses a seed--dialogue hierarchical bootstrap and paired dialogue-cluster permutation; Holm correction spans 72 declared deployable+oracle comparisons. All six DailyDialog gains, all six MELD-mm gains, and DialogueRNN's MELD gain survive correction}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Oracle information-matched shift ROC--AUC (three-seed mean). Both the transition baseline and every learned model receive gold current emotion. Bold values exceed Trans-Gold. DailyDialog and MELD-mm gains survive joint Holm correction; on MELD, four of the six negative differences survive.}}{7}{table.8}\protected@file@percent }
\newlabel{tab:oracle}{{8}{7}{Oracle information-matched shift ROC--AUC (three-seed mean). Both the transition baseline and every learned model receive gold current emotion. Bold values exceed Trans-Gold. DailyDialog and MELD-mm gains survive joint Holm correction; on MELD, four of the six negative differences survive}{table.8}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Strict utterance-local feature control (three-seed ROC--AUC). Both the GRU features and the baseline's current-emotion classifier are refit from the same train-only TF--IDF/SVD rows. Intervals and $p$-values use the same seed--dialogue procedures as the main experiment.}}{7}{table.9}\protected@file@percent }
\newlabel{tab:feat}{{9}{7}{Strict utterance-local feature control (three-seed ROC--AUC). Both the GRU features and the baseline's current-emotion classifier are refit from the same train-only TF--IDF/SVD rows. Intervals and $p$-values use the same seed--dialogue procedures as the main experiment}{table.9}{}}
