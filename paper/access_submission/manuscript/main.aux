\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Dataset statistics and F1 degeneracy. Always-shift F1 $=2r/(1{+}r)$ for shift rate $r$ (analytic; always-shift balanced accuracy is 0.500 by construction, omitted). Transition-BA $\approx $0.50 on MELD/EmoryNLP/IEMOCAP-mm shows standard F1 sits at the degenerate ceiling on exactly the corpora where shift is common; only IEMOCAP and DailyDialog clear it.}}{5}{table.2}\protected@file@percent }
\newlabel{tab:stats}{{2}{5}{Dataset statistics and F1 degeneracy. Always-shift F1 $=2r/(1{+}r)$ for shift rate $r$ (analytic; always-shift balanced accuracy is 0.500 by construction, omitted). Transition-BA $\approx $0.50 on MELD/EmoryNLP/IEMOCAP-mm shows standard F1 sits at the degenerate ceiling on exactly the corpora where shift is common; only IEMOCAP and DailyDialog clear it}{table.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Speaker relation and target composition on the four unique test corpora. Same-next is $P(s_{n+1}=s_n)$. Self-shift uses the next-own-utterance target in Eq.\nobreakspace  {}\textup  {\hbox {\mathsurround \z@ \normalfont  (\ignorespaces \ref  {eq:self}\unskip \@@italiccorr )}}; gap is the mean number of turns from $n$ to $g(n)$. IEMOCAP/MELD multimodal configurations have the same test labels and are therefore not duplicated.}}{6}{table.3}\protected@file@percent }
\newlabel{tab:speaker}{{3}{6}{Speaker relation and target composition on the four unique test corpora. Same-next is $P(s_{n+1}=s_n)$. Self-shift uses the next-own-utterance target in Eq.~\eqref {eq:self}; gap is the mean number of turns from $n$ to $g(n)$. IEMOCAP/MELD multimodal configurations have the same test labels and are therefore not duplicated}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Speaker composition and emotion-shift rate at adjacent test decision points. Filled blue bars denote same-speaker transitions; hatched bars denote speaker switches, preserving the distinction in grayscale. DailyDialog has no adjacent same-speaker decisions. Exact denominators are given in Table\nobreakspace  {}\ref  {tab:speaker}.}}{6}{figure.1}\protected@file@percent }
\newlabel{fig:speaker}{{1}{6}{Speaker composition and emotion-shift rate at adjacent test decision points. Filled blue bars denote same-speaker transitions; hatched bars denote speaker switches, preserving the distinction in grayscale. DailyDialog has no adjacent same-speaker decisions. Exact denominators are given in Table~\ref {tab:speaker}}{figure.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Train-fold transition baselines under the two targets (test AUC). Global conditions only on current emotion; speaker conditions on current emotion and speaker with sparse/unseen-speaker backoff. These are label-only diagnostics, not learned-model results.}}{6}{table.4}\protected@file@percent }
\newlabel{tab:selfbase}{{4}{6}{Train-fold transition baselines under the two targets (test AUC). Global conditions only on current emotion; speaker conditions on current emotion and speaker with sparse/unseen-speaker backoff. These are label-only diagnostics, not learned-model results}{table.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Self-shift composition by forecast gap. Cells show test $N$ / shift rate; -- indicates that the released test split contains no decision at that gap.}}{6}{table.5}\protected@file@percent }
